# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=ecosphere_secret
POSTGRES_DB=ecosphere
DATABASE_URL=postgresql+asyncpg://ecosphere:ecosphere_secret@postgres:5432/ecosphere

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=ecosphere
MINIO_USE_SSL=false

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws

# ── ESG Score Weights (must sum to 1.0, configurable via Settings UI) ─────────
ESG_WEIGHT_ENVIRONMENTAL=0.40
ESG_WEIGHT_SOCIAL=0.30
ESG_WEIGHT_GOVERNANCE=0.30

# ── Email (optional, for notification emails) ─────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@ecosphere.app
SMTP_PASSWORD=
SMTP_FROM=EcoSphere <notifications@ecosphere.app>
